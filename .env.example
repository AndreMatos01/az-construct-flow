##
## Backend (Quarkus)
##
# Copie este arquivo para `.env` e preencha os valores.
# No Windows PowerShell, você também pode exportar como variáveis de ambiente.

# JDBC (Render Postgres: use a URL externa ou interna do painel e converta para jdbc:)
# Ex.: postgresql://user:pass@host:5432/dbname  ->  jdbc:postgresql://host:5432/dbname?sslmode=require
DB_JDBC_URL=jdbc:postgresql://HOST:5432/DB?sslmode=require
DB_USERNAME=seu_usuario
DB_PASSWORD=sua_senha

# No Render (Web Service → Environment): defina as três variáveis acima.
# Se o Postgres for no Render, "sslmode=require" costuma ser necessário na URL JDBC.

##
## Frontend (Vite)
##
VITE_API_BASE_URL=http://localhost:8080

